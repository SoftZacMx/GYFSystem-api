NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=files_manager

JWT_SECRET=change-me-in-production

CORS_ORIGIN=*

# URL base del frontend (enlaces de correo: verificación, reset password)
APP_URL=http://localhost:5173

# S3 / MinIO (local: docker compose; crear bucket files-manager-dev en http://localhost:9001)
S3_REGION=us-east-1
S3_BUCKET=files-manager-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
