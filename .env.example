NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=files_manager

JWT_SECRET=change-me-in-production

CORS_ORIGIN=*

# URL base del frontend (enlaces de correo: verificación, reset password)
APP_URL=http://localhost:5173

# S3 / MinIO (local: docker compose; crear bucket files-manager-dev en http://localhost:9001)
S3_REGION=us-east-1
S3_BUCKET=files-manager-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# Correo: solo AWS SES, con las mismas credenciales que S3. El usuario IAM debe tener permiso ses:SendEmail.
# El remitente (From) debe ser identidad verificada en SES (o configurar en Company en BD).
# AWS_SES_REGION=us-east-1   # opcional; si no se define se usa S3_REGION
# SMTP_FROM=Nombre <correo@dominio.com>   # remitente por defecto (o en Company); debe estar verificado en SES

# Clave para cifrar la contraseña SMTP guardada en company (mín. 32 caracteres en producción)
ENCRYPTION_KEY=dev-encryption-key-min-32-chars!!
