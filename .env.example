NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=files_manager

JWT_SECRET=change-me-in-production

CORS_ORIGIN=*

# URL base del frontend (enlaces de correo: verificación, reset password)
APP_URL=http://localhost:5173

# S3 / MinIO (local: docker compose; crear bucket files-manager-dev en http://localhost:9001)
S3_REGION=us-east-1
S3_BUCKET=files-manager-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# Correo: SMTP (local) o Resend API (Railway/producción). Si RESEND_API_KEY está definido, se usa Resend por HTTPS.
# SMTP: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM
# Resend: obtener API key en https://resend.com/api-keys. El "from" debe ser un dominio verificado en Resend.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# SMTP_FROM=GYF System <onboarding@resend.dev>

# Clave para cifrar la contraseña SMTP guardada en company (mín. 32 caracteres en producción)
ENCRYPTION_KEY=dev-encryption-key-min-32-chars!!
